# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your token.

# Your GitHub username (exactly as it appears on github.com)
GITHUB_USERNAME=your-github-username

# GitHub Personal Access Token with read:user scope
# Create one at: https://github.com/settings/tokens
GH_PRIVATE_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# SVG theme: dark | light | cyberpunk | high-contrast
THEME=dark

# Years of contribution history to fetch (1–5)
YEARS=1
